# Configuración Backend - Lumina App

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=redsocial

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API Key para Chatbot IA (Groq es gratis)
GROQ_API_KEY=your-groq-api-key-here

# Puerto del servicio principal (foro-estudiantes)
PORT=4300
